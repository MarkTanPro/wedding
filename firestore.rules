rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { 
      return isSignedIn() && isEmailVerified() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); 
    }
    function isOwner(data) { return isSignedIn() && data.uid == request.auth.uid; }

    // RSVP Validation Blueprint
    function isValidRSVP(data) {
      return data.keys().hasAll(['name', 'email', 'attendance', 'createdAt', 'uid']) &&
             data.keys().size() >= 5 && data.keys().size() <= 8 &&
             data.name is string && data.name.size() >= 2 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.attendance in ['yes', 'no'] &&
             data.uid is string && data.uid.size() <= 128 &&
             (data.get('guests', null) == null || (data.guests is string && data.guests.size() <= 2)) && // Form sends string for guests
             (data.get('dietary', null) == null || (data.dietary is string && data.dietary.size() <= 500)) &&
             (data.get('message', null) == null || (data.message is string && data.message.size() <= 5000));
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && isValidId(adminId);
      // Writes to admins should only be via internal tools or manual console intervention
    }

    match /rsvps/{rsvpId} {
      // 8. Secure List Queries
      allow list: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      
      // 3. Path Variable Hardening
      allow get: if (isAdmin() || isOwner(existing())) && isValidId(rsvpId);
      
      allow create: if isSignedIn() && isEmailVerified() && isValidId(rsvpId) && 
                      isValidRSVP(incoming()) && 
                      incoming().uid == request.auth.uid &&
                      incoming().createdAt == request.time;
      
      // 4. Tiered Identity Logic & 9. Immortal Fields
      allow update: if isSignedIn() && isEmailVerified() && isValidId(rsvpId) && (
        isAdmin() || (
          isOwner(existing()) && 
          isValidRSVP(incoming()) &&
          incoming().uid == existing().uid &&
          incoming().createdAt == existing().createdAt &&
          incoming().email == existing().email &&
          // Action-Based Pattern
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'attendance', 'guests', 'dietary', 'message'])
        )
      );
      
      allow delete: if isAdmin();
    }
  }
}
