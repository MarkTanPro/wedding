{
  "entities": {
    "RSVP": {
      "title": "RSVP",
      "description": "A wedding RSVP response",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Guest's full name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Guest's email address"
        },
        "attendance": {
          "type": "string",
          "enum": ["yes", "no"],
          "description": "Whether the guest is attending"
        },
        "guests": {
          "type": "integer",
          "description": "Number of guests"
        },
        "dietary": {
          "type": "string",
          "description": "Dietary requirements"
        },
        "message": {
          "type": "string",
          "description": "Optional message for the couple"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Server timestamp when the RSVP was submitted"
        },
        "uid": {
          "type": "string",
          "description": "The user ID of the person who submitted the RSVP"
        }
      },
      "required": ["name", "email", "attendance", "createdAt", "uid"]
    }
  },
  "firestore": {
    "/rsvps/{rsvpId}": {
      "schema": "RSVP",
      "description": "Collection of wedding RSVPs"
    }
  }
}
